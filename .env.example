# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI APIs
DEEPSEEK_API_KEY=sk-your-deepseek-key
ANTHROPIC_API_KEY=sk-ant-your-key-here # Optional if still used
GOOGLE_AI_API_KEY=AIza-your-key-here # Optional

# Facebook App (For Publisher)
FACEBOOK_APP_ID=your-fb-app-id
FACEBOOK_APP_SECRET=your-fb-app-secret
NEXT_PUBLIC_APP_URL=https://your-production-url.com

# Vercel Cron Secret
CRON_SECRET=your-random-secret-here

# Token Encryption (AES-256-GCM) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-hex-char-key-here
